<!DOCTYPE html>
<html lang="ar" dir="rtl" id="html-root">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Cafe Mazaj — أفضل مقهى مصري يقدم القهوة والمشروبات والحلويات بتجربة فريدة" />
    <title>@ViewData["Title"] — كافيه مزاج</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&family=Tajawal:wght@300;400;500;700&family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- GLightbox -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ═══════════════════════════ NAVBAR ═══════════════════════════ -->
    <nav class="navbar navbar-expand-lg cafe-navbar fixed-top" id="main-navbar">
        <div class="container">
            <!-- Brand -->
            <a class="navbar-brand cafe-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-icon">☕</span>
                <span data-lang-ar>كافيه مزاج</span>
                <span data-lang-en style="display:none">Cafe Mazaj</span>
            </a>

            <!-- Mobile Toggle -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <i class="bi bi-list text-white fs-4"></i>
            </button>

            <!-- Nav Links -->
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav mx-auto gap-1">
                    <li class="nav-item">
                        <a class="nav-link cafe-nav-link" asp-controller="Home" asp-action="Index">
                            <span data-lang-ar>الرئيسية</span><span data-lang-en style="display:none">Home</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link cafe-nav-link" asp-controller="Menu" asp-action="Index">
                            <span data-lang-ar>القائمة</span><span data-lang-en style="display:none">Menu</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link cafe-nav-link" asp-controller="Gallery" asp-action="Index">
                            <span data-lang-ar>المعرض</span><span data-lang-en style="display:none">Gallery</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link cafe-nav-link" asp-controller="Reservation" asp-action="Index">
                            <span data-lang-ar>حجز طاولة</span><span data-lang-en style="display:none">Reserve</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link cafe-nav-link" asp-controller="Contact" asp-action="Index">
                            <span data-lang-ar>تواصل معنا</span><span data-lang-en style="display:none">Contact</span>
                        </a>
                    </li>
                </ul>

                <!-- Language Toggle + Reserve CTA -->
                <div class="d-flex align-items-center gap-3">
                    <button class="lang-toggle" id="langToggleBtn" onclick="toggleLang()">
                        <span data-lang-ar>EN</span>
                        <span data-lang-en style="display:none">ع</span>
                    </button>
                    <a asp-controller="Reservation" asp-action="Index" class="btn cafe-btn-primary">
                        <span data-lang-ar>احجز الآن</span>
                        <span data-lang-en style="display:none">Reserve Now</span>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- ═══════════════════════════ CONTENT ═══════════════════════════ -->
    <main>
        @RenderBody()
    </main>

    <!-- ═══════════════════════════ FOOTER ═══════════════════════════ -->
    <footer class="cafe-footer">
        <div class="container">
            <div class="row gy-4">
                <div class="col-lg-4">
                    <div class="footer-brand">
                        <span class="brand-icon fs-3">☕</span>
                        <h5>
                            <span data-lang-ar>كافيه مزاج</span>
                            <span data-lang-en style="display:none">Cafe Mazaj</span>
                        </h5>
                    </div>
                    <p class="footer-tagline mt-2">
                        <span data-lang-ar>حيث تلتقي القهوة بالأجواء</span>
                        <span data-lang-en style="display:none">Where coffee meets ambiance</span>
                    </p>
                    <div class="social-icons mt-3">
                        <a href="#" class="social-icon"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-tiktok"></i></a>
                    </div>
                </div>
                <div class="col-lg-4">
                    <h6 class="footer-heading">
                        <span data-lang-ar>روابط سريعة</span>
                        <span data-lang-en style="display:none">Quick Links</span>
                    </h6>
                    <ul class="footer-links">
                        <li><a asp-controller="Menu" asp-action="Index"><span data-lang-ar>القائمة</span><span data-lang-en style="display:none">Menu</span></a></li>
                        <li><a asp-controller="Gallery" asp-action="Index"><span data-lang-ar>المعرض</span><span data-lang-en style="display:none">Gallery</span></a></li>
                        <li><a asp-controller="Reservation" asp-action="Index"><span data-lang-ar>حجز طاولة</span><span data-lang-en style="display:none">Reservation</span></a></li>
                        <li><a asp-controller="Contact" asp-action="Index"><span data-lang-ar>تواصل معنا</span><span data-lang-en style="display:none">Contact</span></a></li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <h6 class="footer-heading">
                        <span data-lang-ar>تواصل معنا</span>
                        <span data-lang-en style="display:none">Contact Us</span>
                    </h6>
                    <ul class="footer-contact">
                        <li><i class="bi bi-geo-alt-fill"></i> <span data-lang-ar>القاهرة، مصر</span><span data-lang-en style="display:none">Cairo, Egypt</span></li>
                        <li><i class="bi bi-telephone-fill"></i> <a href="tel:+20100000000">+20 100 000 0000</a></li>
                        <li><i class="bi bi-clock-fill"></i> <span data-lang-ar>يومياً ٨ص – ١٢م</span><span data-lang-en style="display:none">Daily 8AM – 12AM</span></li>
                    </ul>
                </div>
            </div>
            <hr class="footer-divider" />
            <p class="footer-copy text-center">
                © 2026 <span data-lang-ar>كافيه مزاج</span><span data-lang-en style="display:none">Cafe Mazaj</span>.
                <span data-lang-ar>جميع الحقوق محفوظة</span><span data-lang-en style="display:none">All rights reserved</span>.
            </p>
        </div>
    </footer>

    <!-- ═══════════════════════════ SCRIPTS ═══════════════════════════ -->
    <!-- Bootstrap 5 -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- GSAP + ScrollTrigger -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <!-- GLightbox -->
    <script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>

    <!-- Site JS -->
    <script src="~/js/lang.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
