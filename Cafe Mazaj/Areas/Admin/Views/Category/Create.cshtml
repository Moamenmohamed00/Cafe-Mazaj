@model Cafe_Mazaj.Models.Entities.Category
@{
    ViewData["Title"] = "Add Category";
}
<div class="row justify-content-center"><div class="col-md-6">
<div class="admin-card">
    <div class="admin-card-header">
        <h6 class="admin-card-title">New Category</h6>
        <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn-admin-outline btn-sm">← Back</a>
    </div>
    <div class="admin-card-body">
        <form asp-area="Admin" asp-controller="Category" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="admin-form-label">Name (English) *</label>
                <input asp-for="NameEn" class="form-control admin-input" placeholder="e.g. Coffee" />
            </div>
            <div class="mb-3">
                <label class="admin-form-label">Name (Arabic) *</label>
                <input asp-for="NameAr" class="form-control admin-input" dir="rtl" placeholder="مثال: قهوة" />
            </div>
            <div class="mb-3">
                <label class="admin-form-label">Sort Order</label>
                <input asp-for="SortOrder" type="number" class="form-control admin-input" value="0" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn-admin-primary"><i class="bi bi-check-lg"></i> Create</button>
                <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn-admin-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>
</div></div>
