@model IEnumerable<Cafe_Mazaj.Models.Entities.Category>
@{
    ViewData["Title"] = "Categories";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0" style="color:var(--admin-text)">Categories (@Model.Count())</h5>
    <a asp-area="Admin" asp-controller="Category" asp-action="Create" class="btn-admin-primary">
        <i class="bi bi-plus-lg"></i> Add Category
    </a>
</div>

<div class="admin-card">
    <table class="admin-table">
        <thead>
            <tr><th>#</th><th>Name (EN)</th><th>Name (AR)</th><th>Slug</th><th>Sort Order</th><th>Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var c in Model.OrderBy(x => x.SortOrder))
            {
                <tr>
                    <td style="color:var(--admin-muted)">@c.Id</td>
                    <td class="fw-semibold">@c.NameEn</td>
                    <td>@c.NameAr</td>
                    <td><code style="color:var(--admin-primary)">@c.Slug</code></td>
                    <td>@c.SortOrder</td>
                    <td>
                        <div class="d-flex gap-2">
                            <a asp-area="Admin" asp-controller="Category" asp-action="Edit" asp-route-id="@c.Id" class="btn-admin-outline btn-sm">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-area="Admin" asp-controller="Category" asp-action="Delete" asp-route-id="@c.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger" data-confirm="Delete '@c.NameEn'?">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts { <script src="~/js/admin.js" asp-append-version="true"></script> }
