<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin | Cafe Mazaj</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- Admin CSS -->
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="admin-body">

<div class="admin-wrapper">

    <!-- ══════════════ SIDEBAR ══════════════ -->
    <aside class="admin-sidebar" id="admin-sidebar">
        <div class="sidebar-header">
            <span class="sidebar-logo">☕</span>
            <div>
                <div class="sidebar-brand">Cafe Mazaj</div>
                <div class="sidebar-role">Admin Panel</div>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-label">MAIN</div>
            <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
               asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>
            <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")"
               asp-area="Admin" asp-controller="Product" asp-action="Index">
                <i class="bi bi-cup-hot"></i> Products
            </a>
            <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")"
               asp-area="Admin" asp-controller="Category" asp-action="Index">
                <i class="bi bi-tags"></i> Categories
            </a>

            <div class="nav-section-label mt-3">OPERATIONS</div>
            <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reservation" ? "active" : "")"
               asp-area="Admin" asp-controller="Reservation" asp-action="Index">
                <i class="bi bi-calendar-check"></i> Reservations
            </a>
            <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Gallery" ? "active" : "")"
               asp-area="Admin" asp-controller="Gallery" asp-action="Index">
                <i class="bi bi-images"></i> Gallery
            </a>
            <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Message" ? "active" : "")"
               asp-area="Admin" asp-controller="Message" asp-action="Index">
                <i class="bi bi-envelope"></i> Messages
            </a>

            <div class="nav-section-label mt-3">SITE</div>
            <a class="sidebar-link" href="/" target="_blank">
                <i class="bi bi-box-arrow-up-right"></i> View Site
            </a>
        </nav>

        <div class="sidebar-footer">
            <div class="admin-user-info">
                <i class="bi bi-person-circle fs-4"></i>
                <div>
                    <div class="fw-semibold">Administrator</div>
                    <div class="small" style="color: var(--admin-muted);">@Context.Session.GetString("AdminUsername")</div>
                </div>
            </div>
            <form asp-area="Admin" asp-controller="Auth" asp-action="Logout" method="post" class="mt-2">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </button>
            </form>
        </div>
    </aside>

    <!-- ══════════════ MAIN CONTENT ══════════════ -->
    <div class="admin-main">
        <header class="admin-topbar">
            <button class="sidebar-toggle-btn" id="sidebarToggle" onclick="toggleSidebar()">
                <i class="bi bi-list fs-4"></i>
            </button>
            <h1 class="admin-page-title">@ViewData["Title"]</h1>
            <div class="topbar-right">
                <span class="text-muted small">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</span>
            </div>
        </header>

        <div class="admin-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/admin.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
