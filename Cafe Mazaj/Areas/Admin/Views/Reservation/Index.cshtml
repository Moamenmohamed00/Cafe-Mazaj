@model Cafe_Mazaj.Models.ViewModels.Admin.ReservationListViewModel
@{
    ViewData["Title"] = "Reservations";
}

<!-- Filter Tabs -->
<ul class="nav nav-tabs mb-4" style="border-color:var(--admin-border)">
    <li class="nav-item">
        <a class="nav-link @(Model.StatusFilter == null ? "active" : "")" asp-area="Admin" asp-controller="Reservation" asp-action="Index"
           style="color:var(--admin-muted)">All (@(Model.PendingCount + Model.ApprovedCount + Model.RejectedCount))</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(Model.StatusFilter == "Pending" ? "active" : "")"
           asp-area="Admin" asp-controller="Reservation" asp-action="Index" asp-route-status="Pending"
           style="color:var(--admin-warning)">Pending (@Model.PendingCount)</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(Model.StatusFilter == "Approved" ? "active" : "")"
           asp-area="Admin" asp-controller="Reservation" asp-action="Index" asp-route-status="Approved"
           style="color:var(--admin-success)">Approved (@Model.ApprovedCount)</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(Model.StatusFilter == "Rejected" ? "active" : "")"
           asp-area="Admin" asp-controller="Reservation" asp-action="Index" asp-route-status="Rejected"
           style="color:var(--admin-danger)">Rejected (@Model.RejectedCount)</a>
    </li>
</ul>

<div class="admin-card">
    <div style="overflow-x:auto">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Customer</th>
                    <th>Phone</th>
                    <th>Date</th>
                    <th>Guests</th>
                    <th>Status</th>
                    <th>Submitted</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Reservations)
                {
                    <tr>
                        <td style="color:var(--admin-muted)">#@r.Id</td>
                        <td class="fw-semibold">@r.CustomerName</td>
                        <td>@r.Phone</td>
                        <td>@r.ReservationDate.ToString("dd MMM yyyy")</td>
                        <td>@r.GuestCount</td>
                        <td><span class="admin-badge badge-@r.Status.ToLower()">@r.Status</span></td>
                        <td style="color:var(--admin-muted)">@r.CreatedAt.ToString("dd MMM, HH:mm")</td>
                        <td>
                            <div class="d-flex gap-1 flex-wrap">
                                <a asp-area="Admin" asp-controller="Reservation" asp-action="Detail" asp-route-id="@r.Id"
                                   class="btn-admin-outline btn-sm"><i class="bi bi-eye"></i></a>
                                @if (r.Status == "Pending")
                                {
                                    <form asp-area="Admin" asp-controller="Reservation" asp-action="Approve" asp-route-id="@r.Id" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm" style="background:rgba(16,185,129,0.15);color:#10B981;border:1px solid #10B981"
                                                data-confirm="Approve this reservation?">
                                            <i class="bi bi-check"></i>
                                        </button>
                                    </form>
                                    <form asp-area="Admin" asp-controller="Reservation" asp-action="Reject" asp-route-id="@r.Id" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm" style="background:rgba(239,68,68,0.15);color:#EF4444;border:1px solid #EF4444"
                                                data-confirm="Reject this reservation?">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Reservations.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">No reservations found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin.js" asp-append-version="true"></script>
}
