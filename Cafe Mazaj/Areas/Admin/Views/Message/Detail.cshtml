@model Cafe_Mazaj.Models.Entities.ContactMessage
@{
    ViewData["Title"] = "Message Detail";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="admin-card">
            <div class="admin-card-header">
                <h6 class="admin-card-title">Message from @Model.SenderName</h6>
                <a asp-area="Admin" asp-controller="Message" asp-action="Index" class="btn-admin-outline btn-sm">← Back</a>
            </div>
            <div class="admin-card-body">
                <div class="row g-3 mb-3">
                    <div class="col-sm-6">
                        <div class="admin-form-label">Name</div>
                        <div class="fw-semibold">@Model.SenderName</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="admin-form-label">Email</div>
                        <a href="mailto:@Model.Email" style="color:var(--admin-primary)">@Model.Email</a>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Phone))
                    {
                        <div class="col-sm-6">
                            <div class="admin-form-label">Phone</div>
                            <a href="tel:@Model.Phone" style="color:var(--admin-primary)">@Model.Phone</a>
                        </div>
                    }
                    <div class="col-sm-6">
                        <div class="admin-form-label">Received</div>
                        <div style="color:var(--admin-muted)">@Model.ReceivedAt.ToString("dd MMM yyyy, HH:mm")</div>
                    </div>
                </div>
                <hr style="border-color:var(--admin-border)" />
                <div class="admin-form-label">Message</div>
                <div style="background:var(--admin-surface-2);border-radius:8px;padding:1.25rem;white-space:pre-line;line-height:1.7">@Model.Message</div>

                <div class="mt-3">
                    <a href="mailto:@Model.Email?subject=Re: Your message to Cafe Mazaj" class="btn-admin-primary">
                        <i class="bi bi-reply me-1"></i> Reply via Email
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
