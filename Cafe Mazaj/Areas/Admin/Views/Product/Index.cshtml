@model IEnumerable<Cafe_Mazaj.Models.Entities.Product>
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0" style="color:var(--admin-text)">All Products (@Model.Count())</h5>
    <a asp-area="Admin" asp-controller="Product" asp-action="Create" class="btn-admin-primary">
        <i class="bi bi-plus-lg"></i> Add Product
    </a>
</div>

<div class="admin-card">
    <div style="overflow-x:auto">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Name (EN)</th>
                    <th>Name (AR)</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Available</th>
                    <th>Featured</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(p.ImagePath))
                            {
                                <img src="@p.ImagePath" class="product-img-preview" alt="@p.NameEn" style="width:60px;height:60px" />
                            }
                            else
                            {
                                <div style="width:60px;height:60px;background:var(--admin-surface-2);border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--admin-muted)">
                                    <i class="bi bi-image"></i>
                                </div>
                            }
                        </td>
                        <td>@p.NameEn</td>
                        <td>@p.NameAr</td>
                        <td>@(p.Category?.NameEn ?? "-")</td>
                        <td>@p.Price EGP</td>
                        <td>
                            @if (p.IsAvailable)
                            { <span class="admin-badge badge-approved"><i class="bi bi-check"></i> Yes</span> }
                            else
                            { <span class="admin-badge badge-rejected"><i class="bi bi-x"></i> No</span> }
                        </td>
                        <td>
                            @if (p.IsFeatured)
                            { <span class="admin-badge badge-pending"><i class="bi bi-star-fill"></i> Yes</span> }
                            else
                            { <span style="color:var(--admin-muted);font-size:0.8rem">-</span> }
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-area="Admin" asp-controller="Product" asp-action="Edit" asp-route-id="@p.Id"
                                   class="btn-admin-outline btn-sm"><i class="bi bi-pencil"></i></a>
                                <form asp-area="Admin" asp-controller="Product" asp-action="Delete" asp-route-id="@p.Id" method="post" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            data-confirm="Delete '@p.NameEn'?">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">No products yet. <a asp-area="Admin" asp-controller="Product" asp-action="Create">Add one</a></td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
