@model Cafe_Mazaj.Models.ViewModels.Admin.ProductFormViewModel
@{
    ViewData["Title"] = "Edit Product";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="admin-card">
            <div class="admin-card-header">
                <h6 class="admin-card-title"><i class="bi bi-pencil me-2"></i>Edit: @Model.NameEn</h6>
                <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn-admin-outline btn-sm">← Back</a>
            </div>
            <div class="admin-card-body">
                <form asp-area="Admin" asp-controller="Product" asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="admin-form-label">Name (English) *</label>
                            <input asp-for="NameEn" class="form-control admin-input" />
                            <span asp-validation-for="NameEn" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="admin-form-label">Name (Arabic) *</label>
                            <input asp-for="NameAr" class="form-control admin-input" dir="rtl" />
                            <span asp-validation-for="NameAr" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="admin-form-label">Description (English)</label>
                            <textarea asp-for="DescriptionEn" class="form-control admin-input" rows="3"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="admin-form-label">Description (Arabic)</label>
                            <textarea asp-for="DescriptionAr" class="form-control admin-input" rows="3" dir="rtl"></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="admin-form-label">Price (EGP) *</label>
                            <input asp-for="Price" type="number" step="0.01" class="form-control admin-input" />
                        </div>
                        <div class="col-md-4">
                            <label class="admin-form-label">Category *</label>
                            <select asp-for="CategoryId" asp-items="Model.CategoryOptions" class="form-select admin-input">
                                <option value="">— Select —</option>
                            </select>
                        </div>
                        <div class="col-md-4 d-flex align-items-end gap-3 pb-1">
                            <div class="form-check">
                                <input asp-for="IsAvailable" class="form-check-input" type="checkbox" id="isAvail" />
                                <label class="form-check-label text-muted" for="isAvail">Available</label>
                            </div>
                            <div class="form-check">
                                <input asp-for="IsFeatured" class="form-check-input" type="checkbox" id="isFeat" />
                                <label class="form-check-label text-muted" for="isFeat">Featured</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="admin-form-label">Change Image (leave blank to keep current)</label>
                            @if (!string.IsNullOrEmpty(Model.ExistingImagePath))
                            {
                                <div class="mb-2">
                                    <img src="@Model.ExistingImagePath" class="product-img-preview" alt="Current Image" id="imagePreview" />
                                </div>
                            }
                            <input type="file" name="ImageFile" id="imageFileInput" class="form-control admin-input" accept="image/*" />
                        </div>
                        <div class="col-12 d-flex gap-2 mt-2">
                            <button type="submit" class="btn-admin-primary">
                                <i class="bi bi-check-lg"></i> Save Changes
                            </button>
                            <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn-admin-outline">Cancel</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/admin.js" asp-append-version="true"></script>
}
